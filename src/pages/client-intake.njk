<main id="main">
      <section class="page-hero">
        <div class="section-inner narrow">
          <p class="eyebrow">Unlisted project form</p>
          <h1>Client Website Intake Form</h1>
          <p>This form helps us collect the details needed to plan your website project. Please complete it as accurately as possible so we can prepare your content, structure, style direction, and project requirements.</p>
        </div>
      </section>

      <section class="section section-cream">
        <div class="section-inner intake-card">
          <form action="https://api.web3forms.com/submit" method="POST" data-captcha-form>
            <input type="hidden" name="access_key" value="9786a91c-c3fd-4b9e-ad2d-3d55ec5807d5">
            <input type="hidden" name="subject" value="New client intake form submission">
            <input type="hidden" name="from_name" value="Rose & Paw Digital Designs Client Intake">
            <input type="hidden" name="redirect" value="https://design.roseandpaw.ca/thank-you.html">

            <fieldset>
              <legend>Business Basics</legend>
              <div class="form-grid">
                <label>Business name <small>Legal or public-facing name.</small><input name="business_name" required></label>
                <label>Business type <small>Example: hair salon, contractor, landscaper, digital services.</small><input name="business_type" required></label>
                <label>Location <small>City, province/state, country.</small><input name="location" required></label>
                <label>Service area <small>Example: Lethbridge, Southern Alberta, Canada-wide, online only.</small><input name="service_area" required></label>
              </div>
              <label>Target customer <small>Who is the website mainly for?</small><textarea name="target_customer" rows="4" required></textarea></label>
              <label>Main goal <small>What should visitors do? Call, email, book, request a quote, buy online, etc.</small><textarea name="main_goal" rows="4" required></textarea></label>
            </fieldset>

            <fieldset>
              <legend>Services and Pricing</legend>
              <label>Main services <small>List the main services, one per line.</small><textarea name="main_services" rows="6" required></textarea></label>
              <label>Prices <small>Add prices, price ranges, packages, or write &ldquo;Contact for pricing&rdquo;.</small><textarea name="prices" rows="4"></textarea></label>
              <label>Special offers <small>Example: 15% off first service, free consultation, seasonal discount, no current offer.</small><textarea name="special_offers" rows="4"></textarea></label>
              <label>Service notes <small>Add important details, requirements, exclusions, or package information.</small><textarea name="service_notes" rows="4"></textarea></label>
            </fieldset>

            <fieldset>
              <legend>Brand, Design, and Pages</legend>
              <div class="form-grid">
                <label>Preferred style <small>Example: modern, warm, professional, bold, luxury, local, simple.</small><input name="preferred_style" required></label>
                <label>Colours <small>Include preferred colours and colours to avoid.</small><input name="colours"></label>
                <label>Logo path or logo notes <small>Example: /images/logo.png or note where the logo file is stored.</small><input name="logo_path"></label>
                <label>Images path or image notes <small>Example: /images/ or note where the image files are stored.</small><input name="images_path"></label>
              </div>
              <label>Extra design notes <small>Include anything that should guide the look and feel.</small><textarea name="extra_design_notes" rows="4"></textarea></label>
              <div class="checkbox-group" role="group" aria-labelledby="pages-needed-label">
                <p id="pages-needed-label">Pages needed</p>
                <small>Select all that apply.</small>
                <div class="checkbox-grid">
                  <label><input type="checkbox" name="pages_needed" value="Home"> Home</label>
                  <label><input type="checkbox" name="pages_needed" value="Services"> Services</label>
                  <label><input type="checkbox" name="pages_needed" value="About"> About</label>
                  <label><input type="checkbox" name="pages_needed" value="Pricing"> Pricing</label>
                  <label><input type="checkbox" name="pages_needed" value="Packages"> Packages</label>
                  <label><input type="checkbox" name="pages_needed" value="Gallery"> Gallery</label>
                  <label><input type="checkbox" name="pages_needed" value="Portfolio"> Portfolio</label>
                  <label><input type="checkbox" name="pages_needed" value="Reviews"> Reviews</label>
                  <label><input type="checkbox" name="pages_needed" value="Contact"> Contact</label>
                  <label><input type="checkbox" name="pages_needed" value="FAQ"> FAQ</label>
                  <label><input type="checkbox" name="pages_needed" value="Privacy Policy"> Privacy Policy</label>
                  <label><input type="checkbox" name="pages_needed" value="Blog"> Blog</label>
                  <label><input type="checkbox" name="pages_needed" value="Booking"> Booking</label>
                  <label><input type="checkbox" name="pages_needed" value="Other"> Other</label>
                </div>
              </div>
              <label>Other pages needed <input name="other_pages_needed"></label>
            </fieldset>

            <fieldset>
              <legend>Contact, Links, and Tracking</legend>
              <div class="form-grid">
                <label>Phone <input type="tel" name="phone" autocomplete="tel"></label>
                <label>Email <input type="email" name="email" autocomplete="email" required></label>
                <label>Address <small>Enter address or &ldquo;No public address&rdquo;.</small><input name="address"></label>
                <label>Hours <small>Example: Mon-Fri 9-5, by appointment only, weekends available.</small><input name="hours"></label>
                <label>Google Business Profile link <input type="url" name="google_business_profile_link"></label>
                <label>Reviews link <small>Google review link or another review platform link.</small><input type="url" name="reviews_link"></label>
                <label>GA4 Measurement ID <small>Example: G-XXXXXXXXXX. Leave blank if not set up yet.</small><input name="ga4_measurement_id"></label>
              </div>
              <label>Social links <small>Facebook, Instagram, TikTok, LinkedIn, or other links.</small><textarea name="social_links" rows="4"></textarea></label>
            </fieldset>

            <fieldset>
              <legend>Website References and Content Preferences</legend>
              <label>Competitor sites <small>Add websites for similar businesses in the same area or industry.</small><textarea name="competitor_sites" rows="4"></textarea></label>
              <label>Sites you like <small>Add websites with design, layout, tone, or features you like.</small><textarea name="sites_you_like" rows="4"></textarea></label>
              <label>Sites you dislike <small>Add websites, styles, layouts, or wording to avoid.</small><textarea name="sites_you_dislike" rows="4"></textarea></label>
              <label>Must-have wording <small>Specific phrases, slogans, service descriptions, offers, or policies that must be included.</small><textarea name="must_have_wording" rows="5"></textarea></label>
              <label>Wording to avoid <small>Words, phrases, claims, tone, or promises to avoid.</small><textarea name="wording_to_avoid" rows="5"></textarea></label>
            </fieldset>

            <fieldset>
              <legend>SEO, FAQ, and Final Notes</legend>
            <label>SEO keywords to target <small>Example: hair salon in Lethbridge, website design for a Lethbridge business, local electrician near me.</small><textarea name="seo_keywords" rows="5"></textarea></label>
              <label>Common customer questions <small>Add questions customers often ask. These can be used for an FAQ section.</small><textarea name="common_customer_questions" rows="5"></textarea></label>
              <label>Anything else the website should include <small>Add final notes, concerns, features, or instructions.</small><textarea name="extra_notes" rows="5"></textarea></label>
            </fieldset>

            <div class="h-captcha" data-captcha="true"></div>
            <p class="form-status" data-form-status aria-live="polite" tabindex="-1"></p>
            <button class="button button-primary" type="submit">Submit Client Intake Form</button>
          </form>
        </div>
      </section>
    </main>
